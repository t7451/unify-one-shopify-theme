{% comment %}
  UNIFYONE MODERN COMMERCE THEME
  Section: Featured Collections
  Version: 2.0.0
  Description: Grid of featured product collections with hover effects,
               category imagery, and product counts.
{% endcomment %}

<section
  class="featured-collections section section--{{ section.settings.bg_style }}"
  data-section-id="{{ section.id }}"
  data-section-type="featured-collections"
>
  <div class="container">

    {%- comment -%} Section Header {%- endcomment -%}
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="section-header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2>{{ section.settings.heading }}</h2>
          <span class="heading-rule heading-rule--center"></span>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p>{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Collections Grid {%- endcomment -%}
    <div class="featured-collections__grid featured-collections__grid--{{ section.settings.columns }}">
      {%- for block in section.blocks -%}
        {%- assign collection = collections[block.settings.collection] -%}

        <a
          href="{% if collection != blank %}{{ collection.url }}{% else %}{{ block.settings.custom_url | default: '#' }}{% endif %}"
          class="collection-card"
          {{ block.shopify_attributes }}
        >
          {%- comment -%} Image {%- endcomment -%}
          <div class="collection-card__media">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                srcset="
                  {{ block.settings.image | image_url: width: 400 }} 400w,
                  {{ block.settings.image | image_url: width: 600 }} 600w,
                  {{ block.settings.image | image_url: width: 800 }} 800w
                "
                sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
                alt="{{ block.settings.image.alt | default: block.settings.title }}"
                loading="lazy"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
              >
            {%- elsif collection != blank and collection.featured_image != blank -%}
              <img
                src="{{ collection.featured_image | image_url: width: 800 }}"
                srcset="
                  {{ collection.featured_image | image_url: width: 400 }} 400w,
                  {{ collection.featured_image | image_url: width: 600 }} 600w,
                  {{ collection.featured_image | image_url: width: 800 }} 800w
                "
                sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
                alt="{{ collection.title }}"
                loading="lazy"
                width="{{ collection.featured_image.width }}"
                height="{{ collection.featured_image.height }}"
              >
            {%- else -%}
              <div class="collection-card__placeholder">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
              </div>
            {%- endif -%}

            <div class="collection-card__overlay"></div>

            {%- comment -%} Product Count Badge {%- endcomment -%}
            {%- if collection != blank and section.settings.show_product_count -%}
              <div class="collection-card__count">
                {{ collection.products_count }} {{ collection.products_count | pluralize: 'Item', 'Items' }}
              </div>
            {%- endif -%}
          </div>

          {%- comment -%} Info {%- endcomment -%}
          <div class="collection-card__info">
            <div class="collection-card__text">
              <h3 class="collection-card__title">
                {{ block.settings.title | default: collection.title | default: 'Collection' }}
              </h3>
              {%- if block.settings.description != blank -%}
                <p class="collection-card__description">{{ block.settings.description }}</p>
              {%- elsif collection != blank and collection.description != blank and section.settings.show_description -%}
                <p class="collection-card__description">{{ collection.description | strip_html | truncate: 80 }}</p>
              {%- endif -%}
            </div>
            <span class="collection-card__cta">
              Shop Now
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </div>
        </a>
      {%- endfor -%}
    </div>

    {%- comment -%} View All Link {%- endcomment -%}
    {%- if section.settings.cta_label != blank -%}
      <div class="featured-collections__footer">
        <a href="{{ section.settings.cta_url | default: '/collections' }}" class="btn btn--secondary btn--lg">
          {{ section.settings.cta_label }}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

<style>
  .featured-collections__grid {
    display: grid;
    gap: var(--space-6);
  }

  .featured-collections__grid--2 { grid-template-columns: repeat(2, 1fr); }
  .featured-collections__grid--3 { grid-template-columns: repeat(3, 1fr); }
  .featured-collections__grid--4 { grid-template-columns: repeat(4, 1fr); }

  .featured-collections__footer {
    text-align: center;
    margin-top: var(--space-12);
  }

  /* Collection Card */
  .collection-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    transition: all var(--transition-normal);
    text-decoration: none;
    color: inherit;
  }

  .collection-card:hover {
    border-color: var(--color-accent-primary);
    box-shadow: 0 0 0 1px var(--color-accent-primary), var(--shadow-lg);
    transform: translateY(-4px);
  }

  /* Media */
  .collection-card__media {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4/3;
    background-color: var(--color-bg-dark);
  }

  .collection-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .collection-card:hover .collection-card__media img {
    transform: scale(1.06);
  }

  .collection-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--color-bg-dark) 0%, var(--color-bg-surface) 100%);
    color: var(--color-text-muted);
  }

  .collection-card__placeholder svg {
    width: 64px;
    height: 64px;
  }

  .collection-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(26, 37, 47, 0.8) 0%, rgba(26, 37, 47, 0.1) 60%, transparent 100%);
    transition: opacity var(--transition-normal);
  }

  .collection-card__count {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    background-color: rgba(26, 37, 47, 0.85);
    backdrop-filter: blur(4px);
    color: var(--color-silver-lining);
    font-family: var(--font-heading);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--letter-spacing-wider);
    text-transform: uppercase;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
  }

  /* Info */
  .collection-card__info {
    padding: var(--space-5);
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-4);
    flex: 1;
  }

  .collection-card__title {
    font-family: var(--font-heading);
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-tight);
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
    line-height: var(--line-height-snug);
  }

  .collection-card__description {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    line-height: var(--line-height-normal);
    margin-bottom: 0;
  }

  .collection-card__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    flex-shrink: 0;
    font-family: var(--font-heading);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--letter-spacing-wider);
    text-transform: uppercase;
    color: var(--color-accent-primary);
    transition: gap var(--transition-normal);
  }

  .collection-card__cta svg {
    width: 16px;
    height: 16px;
    transition: transform var(--transition-normal);
  }

  .collection-card:hover .collection-card__cta {
    gap: var(--space-3);
  }

  .collection-card:hover .collection-card__cta svg {
    transform: translateX(4px);
  }

  @media (max-width: 1024px) {
    .featured-collections__grid--4 { grid-template-columns: repeat(2, 1fr); }
    .featured-collections__grid--3 { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .featured-collections__grid--4,
    .featured-collections__grid--3,
    .featured-collections__grid--2 {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Featured Collections",
  "tag": "section",
  "class": "section-featured-collections",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Shop by Category"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore Featured Collections"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Highlight your best categories to help customers shop faster."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns",
      "options": [
        { "value": "2", "label": "2 Columns" },
        { "value": "3", "label": "3 Columns" },
        { "value": "4", "label": "4 Columns" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "bg_style",
      "label": "Background",
      "options": [
        { "value": "dark", "label": "Dark" },
        { "value": "surface", "label": "Surface" },
        { "value": "light", "label": "Light" }
      ],
      "default": "dark"
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Show Product Count",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show Collection Description",
      "default": false
    },
    {
      "type": "header",
      "content": "View All Button"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button Label",
      "default": "Browse All Collections"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Override Title",
          "info": "Leave blank to use collection title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Override Description",
          "info": "Leave blank to use collection description"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Override Image",
          "info": "Leave blank to use collection image"
        },
        {
          "type": "url",
          "id": "custom_url",
          "label": "Custom URL",
          "info": "Used if no collection is selected"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Collections",
      "settings": {
        "eyebrow": "Shop by Category",
        "heading": "Explore Featured Collections",
        "subheading": "Highlight your best categories to help customers shop faster.",
        "columns": "4"
      },
      "blocks": [
        { "type": "collection", "settings": { "title": "New Arrivals" } },
        { "type": "collection", "settings": { "title": "Best Sellers" } },
        { "type": "collection", "settings": { "title": "Seasonal Picks" } },
        { "type": "collection", "settings": { "title": "Shop by Style" } }
      ]
    }
  ]
}
{% endschema %}
