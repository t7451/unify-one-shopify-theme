{% comment %}
  UNIFYONE MODERN COMMERCE THEME
  Section: Trust Bar
  Version: 2.0.0
  Description: Horizontal strip of trust/value proposition icons.
               Configurable icons, titles, and subtitles.
{% endcomment %}

<section
  class="trust-bar-section"
  data-section-id="{{ section.id }}"
  data-section-type="trust-bar"
>
  <div class="container">
    <div class="trust-bar-section__grid">
      {%- for block in section.blocks -%}
        <div class="trust-bar-section__item" {{ block.shopify_attributes }}>
          <div class="trust-bar-section__icon">
            {%- case block.settings.icon -%}
              {%- when 'shipping' -%}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {%- when 'shield' -%}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
              {%- when 'clock' -%}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              {%- when 'return' -%}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/></svg>
              {%- when 'star' -%}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {%- when 'lock' -%}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              {%- when 'phone' -%}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              {%- when 'award' -%}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
              {%- else -%}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            {%- endcase -%}
          </div>
          <div class="trust-bar-section__text">
            <span class="trust-bar-section__title">{{ block.settings.title }}</span>
            {%- if block.settings.subtitle != blank -%}
              <span class="trust-bar-section__subtitle">{{ block.settings.subtitle }}</span>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .trust-bar-section {
    background-color: var(--color-bg-dark);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-6);
  }

  .trust-bar-section__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: var(--space-6);
    align-items: center;
  }

  .trust-bar-section__item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .trust-bar-section__icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(230, 126, 34, 0.1);
    border-radius: var(--radius-md);
    color: var(--color-accent-primary);
    border: 1px solid rgba(230, 126, 34, 0.2);
  }

  .trust-bar-section__icon svg {
    width: 22px;
    height: 22px;
  }

  .trust-bar-section__text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .trust-bar-section__title {
    font-family: var(--font-heading);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
    color: var(--color-text-primary);
    line-height: 1.2;
  }

  .trust-bar-section__subtitle {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    line-height: 1.3;
  }

  @media (max-width: 768px) {
    .trust-bar-section__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-4);
    }
  }

  @media (max-width: 480px) {
    .trust-bar-section__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Trust Bar",
  "tag": "section",
  "class": "section-trust-bar",
  "max_blocks": 6,
  "settings": [],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shipping", "label": "Shipping Truck" },
            { "value": "shield", "label": "Shield / Guarantee" },
            { "value": "clock", "label": "Clock / Speed" },
            { "value": "return", "label": "Returns" },
            { "value": "star", "label": "Star / Quality" },
            { "value": "lock", "label": "Lock / Security" },
            { "value": "phone", "label": "Phone / Support" },
            { "value": "award", "label": "Award" },
            { "value": "check", "label": "Checkmark" }
          ],
          "default": "shield"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Quality Guaranteed"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Every product tested and approved"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Bar",
      "blocks": [
        { "type": "trust_item", "settings": { "icon": "shipping", "title": "Free Shipping", "subtitle": "On orders over $75" } },
        { "type": "trust_item", "settings": { "icon": "shield", "title": "Quality Guaranteed", "subtitle": "Craftsman-approved products" } },
        { "type": "trust_item", "settings": { "icon": "clock", "title": "Same-Day Processing", "subtitle": "Orders before 2pm ship today" } },
        { "type": "trust_item", "settings": { "icon": "return", "title": "30-Day Returns", "subtitle": "Hassle-free return policy" } },
        { "type": "trust_item", "settings": { "icon": "lock", "title": "Secure Checkout", "subtitle": "256-bit SSL encryption" } },
        { "type": "trust_item", "settings": { "icon": "phone", "title": "Expert Support", "subtitle": "Talk to a real craftsman" } }
      ]
    }
  ]
}
{% endschema %}
