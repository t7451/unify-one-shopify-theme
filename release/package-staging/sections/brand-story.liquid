{% comment %}
  UNIFYONE MODERN COMMERCE THEME
  Section: Brand Story / About
  Version: 2.0.0
  Description: Two-column brand story section with image, stats,
               and rich text content. Used on homepage and about page.
{% endcomment %}

<section
  class="brand-story section section--{{ section.settings.bg_style }}"
  data-section-id="{{ section.id }}"
  data-section-type="brand-story"
>
  <div class="container">
    <div class="brand-story__layout brand-story__layout--{{ section.settings.image_position }}">

      {%- comment -%} Image Column {%- endcomment -%}
      <div class="brand-story__media-col">
        <div class="brand-story__media-wrap">
          {%- if section.settings.image != blank -%}
            <img
              class="brand-story__image"
              src="{{ section.settings.image | image_url: width: 900 }}"
              srcset="
                {{ section.settings.image | image_url: width: 500 }} 500w,
                {{ section.settings.image | image_url: width: 700 }} 700w,
                {{ section.settings.image | image_url: width: 900 }} 900w
              "
              sizes="(max-width: 768px) 100vw, 50vw"
              alt="{{ section.settings.image.alt | default: 'Your brand' }}"
              loading="lazy"
              width="{{ section.settings.image.width }}"
              height="{{ section.settings.image.height }}"
            >
          {%- else -%}
            <div class="brand-story__image-placeholder">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            </div>
          {%- endif -%}

          {%- comment -%} Accent Badge {%- endcomment -%}
          {%- if section.settings.badge_text != blank -%}
            <div class="brand-story__badge">
              <span class="brand-story__badge-text">{{ section.settings.badge_text }}</span>
              <span class="brand-story__badge-sub">{{ section.settings.badge_subtext }}</span>
            </div>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Content Column {%- endcomment -%}
      <div class="brand-story__content-col">
        <div class="brand-story__content">

          {%- if section.settings.eyebrow != blank -%}
            <p class="eyebrow">{{ section.settings.eyebrow }}</p>
          {%- endif -%}

          {%- if section.settings.heading != blank -%}
            <h2 class="brand-story__heading">{{ section.settings.heading }}</h2>
            <span class="heading-rule"></span>
          {%- endif -%}

          {%- if section.settings.body_text != blank -%}
            <div class="brand-story__body rte">
              {{ section.settings.body_text }}
            </div>
          {%- endif -%}

          {%- comment -%} Stats Row {%- endcomment -%}
          {%- if section.settings.stat_1_number != blank or section.settings.stat_2_number != blank or section.settings.stat_3_number != blank -%}
            <div class="brand-story__stats">
              {%- if section.settings.stat_1_number != blank -%}
                <div class="brand-story__stat">
                  <span class="brand-story__stat-number">{{ section.settings.stat_1_number }}</span>
                  <span class="brand-story__stat-label">{{ section.settings.stat_1_label }}</span>
                </div>
              {%- endif -%}
              {%- if section.settings.stat_2_number != blank -%}
                <div class="brand-story__stat">
                  <span class="brand-story__stat-number">{{ section.settings.stat_2_number }}</span>
                  <span class="brand-story__stat-label">{{ section.settings.stat_2_label }}</span>
                </div>
              {%- endif -%}
              {%- if section.settings.stat_3_number != blank -%}
                <div class="brand-story__stat">
                  <span class="brand-story__stat-number">{{ section.settings.stat_3_number }}</span>
                  <span class="brand-story__stat-label">{{ section.settings.stat_3_label }}</span>
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}

          {%- if section.settings.cta_label != blank -%}
            <div class="brand-story__cta">
              <a href="{{ section.settings.cta_url | default: '/pages/about' }}" class="btn btn--primary btn--lg">
                {{ section.settings.cta_label }}
              </a>
            </div>
          {%- endif -%}

        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .brand-story__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  .brand-story__layout--right {
    direction: rtl;
  }

  .brand-story__layout--right > * {
    direction: ltr;
  }

  /* Media */
  .brand-story__media-wrap {
    position: relative;
  }

  .brand-story__image {
    width: 100%;
    border-radius: var(--radius-xl);
    object-fit: cover;
    aspect-ratio: 4/5;
    box-shadow: var(--shadow-xl);
  }

  .brand-story__image-placeholder {
    width: 100%;
    aspect-ratio: 4/5;
    background: linear-gradient(135deg, var(--color-bg-dark) 0%, var(--color-bg-surface) 100%);
    border-radius: var(--radius-xl);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
  }

  .brand-story__image-placeholder svg {
    width: 80px;
    height: 80px;
  }

  .brand-story__badge {
    position: absolute;
    bottom: calc(-1 * var(--space-6));
    right: calc(-1 * var(--space-6));
    background-color: var(--color-accent-primary);
    color: var(--color-white);
    width: 120px;
    height: 120px;
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    box-shadow: var(--shadow-orange-lg);
    padding: var(--space-3);
  }

  .brand-story__badge-text {
    font-family: var(--font-heading);
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-black);
    line-height: 1;
  }

  .brand-story__badge-sub {
    font-family: var(--font-heading);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--letter-spacing-wider);
    text-transform: uppercase;
    line-height: 1.2;
    margin-top: var(--space-1);
  }

  /* Content */
  .brand-story__heading {
    font-size: var(--font-size-4xl);
    margin-bottom: var(--space-2);
  }

  .brand-story__body {
    margin-top: var(--space-6);
    margin-bottom: var(--space-8);
  }

  .brand-story__body p {
    font-size: var(--font-size-md);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
  }

  .brand-story__body p:last-child {
    margin-bottom: 0;
  }

  /* Stats */
  .brand-story__stats {
    display: flex;
    gap: var(--space-8);
    margin-bottom: var(--space-8);
    padding-block: var(--space-6);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .brand-story__stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .brand-story__stat-number {
    font-family: var(--font-heading);
    font-size: var(--font-size-4xl);
    font-weight: var(--font-weight-black);
    color: var(--color-accent-primary);
    line-height: 1;
  }

  .brand-story__stat-label {
    font-family: var(--font-heading);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--letter-spacing-wider);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .brand-story__layout,
    .brand-story__layout--right {
      grid-template-columns: 1fr;
      direction: ltr;
      gap: var(--space-8);
    }

    .brand-story__badge {
      right: var(--space-4);
      bottom: calc(-1 * var(--space-4));
      width: 100px;
      height: 100px;
    }

    .brand-story__badge-text {
      font-size: var(--font-size-xl);
    }

    .brand-story__stats {
      gap: var(--space-6);
    }

    .brand-story__stat-number {
      font-size: var(--font-size-3xl);
    }
  }
</style>

{% schema %}
{
  "name": "Brand Story",
  "tag": "section",
  "class": "section-brand-story",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Number",
      "default": "15+"
    },
    {
      "type": "text",
      "id": "badge_subtext",
      "label": "Badge Subtitle",
      "default": "Years in Business"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Our Story"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built for Growing Brands"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body Text",
      "default": "<p>Tell customers what makes your brand unique and why they should trust your products.</p><p>Share your mission, your quality standards, and the value customers can expect with every order.</p>"
    },
    {
      "type": "header",
      "content": "Stats"
    },
    {
      "type": "text",
      "id": "stat_1_number",
      "label": "Stat 1 Number",
      "default": "500+"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 Label",
      "default": "Products"
    },
    {
      "type": "text",
      "id": "stat_2_number",
      "label": "Stat 2 Number",
      "default": "10K+"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 Label",
      "default": "Customers"
    },
    {
      "type": "text",
      "id": "stat_3_number",
      "label": "Stat 3 Number",
      "default": "4.9★"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 Label",
      "default": "Avg Rating"
    },
    {
      "type": "header",
      "content": "CTA"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button Label",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "bg_style",
      "label": "Background",
      "options": [
        { "value": "dark", "label": "Dark" },
        { "value": "surface", "label": "Surface" },
        { "value": "light", "label": "Light" }
      ],
      "default": "surface"
    }
  ],
  "presets": [
    {
      "name": "Brand Story",
      "settings": {
        "eyebrow": "Our Story",
        "heading": "Built for Growing Brands",
        "badge_text": "15+",
        "badge_subtext": "Years in Business",
        "stat_1_number": "500+",
        "stat_1_label": "Products",
        "stat_2_number": "10K+",
        "stat_2_label": "Customers",
        "stat_3_number": "4.9★",
        "stat_3_label": "Avg Rating",
        "cta_label": "Our Story"
      }
    }
  ]
}
{% endschema %}
