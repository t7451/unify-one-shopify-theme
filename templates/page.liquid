{% comment %}
  JIMBO'S IRON & THREAD SUPPLY CO.
  Template: Generic Page
  Version: 2.0.0
  Description: Static content pages (About, FAQ, Privacy, etc.) with
               optional hero banner, rich-text body, and sidebar.
{% endcomment %}

<div class="page-template">

  {%- comment -%} Page Hero {%- endcomment -%}
  <div class="page-hero">
    <div class="container">
      {% render 'breadcrumbs' %}
      <h1 class="page-hero__title">{{ page.title }}</h1>
    </div>
  </div>

  {%- comment -%} Page Content {%- endcomment -%}
  <div class="page-content section section--light">
    <div class="container container--narrow">
      <div class="rte page-content__body">
        {{ page.content }}
      </div>
    </div>
  </div>

</div>

<style>
  .page-hero {
    background-color: var(--color-bg-dark);
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-12) var(--space-10);
  }

  .page-hero__title {
    font-size: clamp(2rem, 4vw, 3.5rem);
    color: var(--color-white);
    margin-top: var(--space-4);
    margin-bottom: 0;
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-tight);
  }

  .page-content__body {
    font-size: var(--font-size-md);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-dark);
  }

  .page-content__body h2,
  .page-content__body h3,
  .page-content__body h4 {
    color: var(--color-text-dark);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .page-content__body p {
    margin-bottom: var(--space-4);
  }

  .page-content__body ul,
  .page-content__body ol {
    margin-bottom: var(--space-4);
    padding-left: var(--space-6);
  }

  .page-content__body li {
    margin-bottom: var(--space-2);
  }

  .page-content__body a {
    color: var(--color-accent-primary);
    text-decoration: underline;
  }

  .page-content__body a:hover {
    color: var(--color-accent-primary-hover);
  }

  .page-content__body img {
    max-width: 100%;
    border-radius: var(--radius-lg);
    margin-block: var(--space-6);
  }

  .page-content__body blockquote {
    border-left: 4px solid var(--color-accent-primary);
    padding-left: var(--space-5);
    margin-left: 0;
    font-style: italic;
    color: var(--color-text-dark-secondary);
  }

  .page-content__body table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: var(--space-6);
  }

  .page-content__body th,
  .page-content__body td {
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border-light);
    text-align: left;
  }

  .page-content__body th {
    background-color: var(--color-bg-light);
    font-weight: var(--font-weight-bold);
    font-family: var(--font-heading);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
    font-size: var(--font-size-sm);
  }

  .section--light .page-content__body {
    color: var(--color-text-dark);
  }
</style>
