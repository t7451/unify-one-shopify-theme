{% comment %}
  JIMBO'S IRON & THREAD SUPPLY CO.
  Template: Search Results
  Version: 2.0.0
  Description: Search results page with product grid, result count,
               and no-results state.
{% endcomment %}

{% paginate search.results by 24 %}

<div class="search-page">

  {%- comment -%} Search Header {%- endcomment -%}
  <div class="search-page__header">
    <div class="container">
      {% render 'breadcrumbs' %}
      <h1 class="search-page__title">
        {%- if search.performed -%}
          {%- if search.results_count > 0 -%}
            {{ search.results_count }} {{ search.results_count | pluralize: 'result', 'results' }} for &ldquo;{{ search.terms | escape }}&rdquo;
          {%- else -%}
            No results for &ldquo;{{ search.terms | escape }}&rdquo;
          {%- endif -%}
        {%- else -%}
          Search
        {%- endif -%}
      </h1>

      {%- comment -%} Search Form {%- endcomment -%}
      <form action="/search" method="get" class="search-page__form" role="search">
        {%- comment -%} No type restriction — search returns products, articles, and pages {%- endcomment -%}
        <div class="search-page__input-group">
          <label for="search-input" class="sr-only">Search products</label>
          <input
            type="search"
            id="search-input"
            name="q"
            class="form-input search-page__input"
            value="{{ search.terms | escape }}"
            placeholder="Search for tools, hardware, thread…"
            autocomplete="off"
            autofocus
          >
          <button type="submit" class="btn btn--primary search-page__submit">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            Search
          </button>
        </div>
      </form>
    </div>
  </div>

  <div class="container">

    {%- if search.performed -%}

      {%- if search.results_count > 0 -%}

        {%- comment -%} Results Grid {%- endcomment -%}
        <div class="search-results__grid">
          {%- for result in search.results -%}
            {%- if result.object_type == 'product' -%}
              {%- assign product = result -%}
              <div class="product-card">

                {%- comment -%} Badge {%- endcomment -%}
                {%- if product.available == false -%}
                  <div class="product-card__badge product-card__badge--sold-out">Sold Out</div>
                {%- elsif product.compare_at_price > product.price -%}
                  {%- assign savings_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
                  <div class="product-card__badge product-card__badge--sale">-{{ savings_pct }}%</div>
                {%- endif -%}

                <a href="{{ product.url }}" class="product-card__media-link" aria-label="{{ product.title | escape }}">
                  <div class="product-card__media">
                    {%- if product.featured_image != blank -%}
                      <img
                        src="{{ product.featured_image | image_url: width: 600 }}"
                        srcset="
                          {{ product.featured_image | image_url: width: 300 }} 300w,
                          {{ product.featured_image | image_url: width: 600 }} 600w
                        "
                        sizes="(max-width: 640px) 50vw, 25vw"
                        alt="{{ product.featured_image.alt | default: product.title | escape }}"
                        loading="lazy"
                        width="{{ product.featured_image.width }}"
                        height="{{ product.featured_image.height }}"
                      >
                    {%- else -%}
                      <div class="product-card__no-image">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                      </div>
                    {%- endif -%}
                  </div>
                </a>

                <div class="product-card__info">
                  {%- if product.vendor != blank -%}
                    <p class="product-card__vendor">{{ product.vendor }}</p>
                  {%- endif -%}
                  <a href="{{ product.url }}" class="product-card__title-link">
                    <h2 class="product-card__title">{{ product.title }}</h2>
                  </a>
                  <div class="product-card__price-wrap">
                    {%- if product.compare_at_price > product.price -%}
                      <span class="product-card__price product-card__price--sale">{{ product.price | money }}</span>
                      <span class="product-card__price--compare">{{ product.compare_at_price | money }}</span>
                    {%- else -%}
                      <span class="product-card__price">{{ product.price | money }}</span>
                    {%- endif -%}
                  </div>
                </div>

              </div>
            {%- elsif result.object_type == 'article' -%}
              <div class="search-result-article">
                <a href="{{ result.url }}" class="search-result-article__link">
                  <p class="search-result-article__type">Article</p>
                  <h2 class="search-result-article__title">{{ result.title }}</h2>
                  <p class="search-result-article__excerpt">{{ result.excerpt | strip_html | truncate: 120 }}</p>
                </a>
              </div>
            {%- elsif result.object_type == 'page' -%}
              <div class="search-result-page">
                <a href="{{ result.url }}" class="search-result-page__link">
                  <p class="search-result-page__type">Page</p>
                  <h2 class="search-result-page__title">{{ result.title }}</h2>
                </a>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- comment -%} Pagination {%- endcomment -%}
        {%- if paginate.pages > 1 -%}
          <nav class="pagination" role="navigation" aria-label="Search results pages">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="pagination__item" rel="prev" aria-label="Previous page">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
              </a>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="pagination__item">{{ part.title }}</a>
              {%- elsif part.title == paginate.current_page -%}
                <span class="pagination__item pagination__item--active" aria-current="page">{{ part.title }}</span>
              {%- else -%}
                <span class="pagination__item pagination__item--ellipsis">{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="pagination__item" rel="next" aria-label="Next page">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
              </a>
            {%- endif -%}
          </nav>
        {%- endif -%}

      {%- else -%}

        {%- comment -%} No Results State {%- endcomment -%}
        <div class="search-no-results">
          <div class="search-no-results__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
          </div>
          <h2 class="search-no-results__heading">No results found</h2>
          <p class="search-no-results__text">
            We couldn't find anything matching &ldquo;<strong>{{ search.terms | escape }}</strong>&rdquo;.
            Try a different search term or browse our collections.
          </p>
          <div class="search-no-results__suggestions">
            <p class="search-no-results__suggestions-label">Try browsing:</p>
            <div class="search-no-results__links">
              <a href="/collections/all" class="btn btn--secondary">All Products</a>
              <a href="/collections" class="btn btn--ghost">All Collections</a>
            </div>
          </div>
        </div>

      {%- endif -%}

    {%- else -%}

      {%- comment -%} Pre-search state {%- endcomment -%}
      <div class="search-prompt">
        <p class="search-prompt__text">Enter a search term above to find products, articles, and pages.</p>
      </div>

    {%- endif -%}

  </div>
</div>

{% endpaginate %}

<style>
  .search-page {
    background-color: var(--color-bg-dark);
    min-height: 60vh;
    padding-bottom: var(--space-20);
  }

  .search-page__header {
    padding-block: var(--space-12) var(--space-10);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-10);
  }

  .search-page__title {
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    color: var(--color-white);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-tight);
    margin-block: var(--space-4) var(--space-6);
  }

  .search-page__input-group {
    display: flex;
    gap: 0;
    max-width: 600px;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: border-color var(--transition-normal);
  }

  .search-page__input-group:focus-within {
    border-color: var(--color-accent-primary);
  }

  .search-page__input {
    flex: 1;
    border: none;
    border-radius: 0;
    background-color: var(--color-bg-surface);
    font-size: var(--font-size-base);
    padding: var(--space-4) var(--space-5);
  }

  .search-page__input:focus { box-shadow: none; }

  .search-page__submit {
    border-radius: 0;
    flex-shrink: 0;
    gap: var(--space-2);
    display: flex;
    align-items: center;
    padding-inline: var(--space-5);
  }

  .search-page__submit svg { width: 18px; height: 18px; }

  /* Results Grid */
  .search-results__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
  }

  /* Article & Page results */
  .search-result-article,
  .search-result-page {
    grid-column: 1 / -1;
  }

  .search-result-article__link,
  .search-result-page__link {
    display: block;
    padding: var(--space-5);
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition-normal);
  }

  .search-result-article__link:hover,
  .search-result-page__link:hover {
    border-color: var(--color-accent-primary);
  }

  .search-result-article__type,
  .search-result-page__type {
    font-family: var(--font-heading);
    font-size: var(--font-size-xs);
    letter-spacing: var(--letter-spacing-wider);
    text-transform: uppercase;
    color: var(--color-accent-primary);
    margin-bottom: var(--space-2);
  }

  .search-result-article__title,
  .search-result-page__title {
    font-size: var(--font-size-xl);
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
  }

  .search-result-article__excerpt {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    line-height: var(--line-height-relaxed);
    margin: 0;
  }

  /* No Results */
  .search-no-results {
    text-align: center;
    padding-block: var(--space-16);
    max-width: 480px;
    margin-inline: auto;
  }

  .search-no-results__icon {
    width: 72px;
    height: 72px;
    margin-inline: auto;
    margin-bottom: var(--space-6);
    color: var(--color-text-muted);
  }

  .search-no-results__icon svg { width: 100%; height: 100%; }

  .search-no-results__heading {
    font-size: var(--font-size-2xl);
    color: var(--color-white);
    margin-bottom: var(--space-3);
  }

  .search-no-results__text {
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    margin-bottom: var(--space-8);
  }

  .search-no-results__suggestions-label {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
  }

  .search-no-results__links {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Prompt */
  .search-prompt {
    text-align: center;
    padding-block: var(--space-12);
    color: var(--color-text-muted);
  }

  @media (max-width: 1024px) {
    .search-results__grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 768px) {
    .search-results__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .search-page__input-group { flex-direction: column; }
    .search-page__submit { border-radius: 0; }
    .search-results__grid { grid-template-columns: 1fr; }
  }
</style>
