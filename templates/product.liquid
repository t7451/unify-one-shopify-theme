{% comment %}
  UNIFYONE MODERN COMMERCE THEME
  Template: Product Detail Page (PDP)
  Version: 2.0.0
  Description: Full-featured product page with image gallery, variant
               selection, quantity picker, trust signals, reviews,
               and related products.
{% endcomment %}

{% render 'product-schema' %}

<div class="pdp" data-product-id="{{ product.id }}">
  <div class="container">

    {%- comment -%} Breadcrumbs {%- endcomment -%}
    {% render 'breadcrumbs' %}

    {%- comment -%} Main Product Layout {%- endcomment -%}
    <div class="pdp__layout">

      {%- comment -%} ===== LEFT: GALLERY ===== {%- endcomment -%}
      <div class="pdp__gallery" data-product-gallery>

        {%- comment -%} Main Image {%- endcomment -%}
        <div class="pdp__main-image-wrap">
          {%- if product.featured_image != blank -%}
            <img
              id="pdp-main-image"
              class="pdp__main-image"
              src="{{ product.featured_image | image_url: width: 900 }}"
              srcset="
                {{ product.featured_image | image_url: width: 500 }} 500w,
                {{ product.featured_image | image_url: width: 700 }} 700w,
                {{ product.featured_image | image_url: width: 900 }} 900w
              "
              sizes="(max-width: 768px) 100vw, 50vw"
              alt="{{ product.featured_image.alt | default: product.title | escape }}"
              loading="eager"
              fetchpriority="high"
              width="{{ product.featured_image.width }}"
              height="{{ product.featured_image.height }}"
            >
          {%- else -%}
            <div class="pdp__main-image-placeholder">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            </div>
          {%- endif -%}

          {%- comment -%} Sale Badge {%- endcomment -%}
          {%- if product.compare_at_price > product.price -%}
            {%- assign savings_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
            <div class="pdp__badge pdp__badge--sale">Save {{ savings_pct }}%</div>
          {%- elsif product.available == false -%}
            <div class="pdp__badge pdp__badge--sold-out">Sold Out</div>
          {%- elsif product.tags contains 'new' -%}
            <div class="pdp__badge pdp__badge--new">New Arrival</div>
          {%- endif -%}
        </div>

        {%- comment -%} Thumbnails {%- endcomment -%}
        {%- if product.images.size > 1 -%}
          <div class="pdp__thumbnails" role="list" aria-label="Product images">
            {%- for image in product.images -%}
              <button
                type="button"
                class="pdp__thumbnail{% if forloop.first %} pdp__thumbnail--active{% endif %}"
                data-gallery-thumb="{{ image | image_url: width: 900 }}"
                aria-label="View image {{ forloop.index }}"
                aria-pressed="{{ forloop.first }}"
                role="listitem"
              >
                <img
                  src="{{ image | image_url: width: 120 }}"
                  alt="{{ image.alt | default: product.title | escape }}"
                  loading="lazy"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                >
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} ===== RIGHT: INFO ===== {%- endcomment -%}
      <div class="pdp__info">

        {%- comment -%} Vendor / Category {%- endcomment -%}
        {%- if product.vendor != blank -%}
          <p class="pdp__vendor eyebrow">{{ product.vendor }}</p>
        {%- endif -%}

        {%- comment -%} Title {%- endcomment -%}
        <h1 class="pdp__title">{{ product.title }}</h1>

        {%- comment -%} Rating Summary {%- endcomment -%}
        <div class="pdp__rating">
          {% render 'judgeme_widgets', widget_type: 'judgeme_preview_badge', jm_style: '', concierge_install: false, product: product %}
        </div>

        {%- comment -%} Price {%- endcomment -%}
        <div class="pdp__price-wrap" id="pdp-price">
          {% render 'price-display', product: product, wrapper_class: 'pdp__price' %}
        </div>

        {%- comment -%} Short Description {%- endcomment -%}
        {%- if product.description != blank -%}
          <div class="pdp__short-desc">
            {{ product.description | strip_html | truncate: 200 }}
          </div>
        {%- endif -%}

        <div class="pdp__divider"></div>

        {%- comment -%} Product Form {%- endcomment -%}
        {%- form 'product', product, id: 'pdp-form', data-product-form: '' -%}

          {%- comment -%} Variant Selector {%- endcomment -%}
          {%- unless product.has_only_default_variant -%}
            {%- for option in product.options_with_values -%}
              <div class="pdp__option form-group">
                <label class="form-label pdp__option-label">
                  {{ option.name }}:
                  <span class="pdp__option-selected" data-option-name="{{ option.name }}">
                    {{ product.selected_or_first_available_variant | map: option.name }}
                  </span>
                </label>

                {%- comment -%} Swatch-style or dropdown depending on option type {%- endcomment -%}
                {%- if option.name == 'Color' or option.name == 'Colour' -%}
                  <div class="pdp__swatches" data-option-position="{{ option.position }}">
                    {%- for value in option.values -%}
                      <button
                        type="button"
                        class="pdp__swatch{% if option.selected_value == value %} pdp__swatch--active{% endif %}"
                        data-value="{{ value }}"
                        aria-label="{{ value }}"
                        title="{{ value }}"
                        style="--swatch-color: {{ value | downcase | replace: ' ', '' }};"
                      >
                        {{ value | truncate: 1, '' }}
                      </button>
                    {%- endfor -%}
                  </div>
                {%- else -%}
                  <div class="pdp__option-buttons" data-option-position="{{ option.position }}">
                    {%- for value in option.values -%}
                      <button
                        type="button"
                        class="pdp__option-btn{% if option.selected_value == value %} pdp__option-btn--active{% endif %}"
                        data-value="{{ value }}"
                      >
                        {{ value }}
                      </button>
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              </div>
            {%- endfor -%}

            <select name="id" id="pdp-variant-select" class="sr-only" aria-label="Product variant">
              {%- for variant in product.variants -%}
                <option
                  value="{{ variant.id }}"
                  {% if variant == product.selected_or_first_available_variant %}selected{% endif %}
                  {% unless variant.available %}disabled{% endunless %}
                  data-price="{{ variant.price }}"
                  data-compare-price="{{ variant.compare_at_price }}"
                >
                  {{ variant.title }}
                </option>
              {%- endfor -%}
            </select>
          {%- else -%}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          {%- endunless -%}

          {%- comment -%} Quantity + ATC Row {%- endcomment -%}
          <div class="pdp__purchase-row">
            <div class="quantity-selector" aria-label="Quantity">
              <button type="button" class="quantity-selector__btn" data-qty-minus aria-label="Decrease quantity">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </button>
              <input
                type="number"
                name="quantity"
                id="pdp-quantity"
                class="quantity-selector__input"
                value="1"
                min="1"
                aria-label="Quantity"
              >
              <button type="button" class="quantity-selector__btn" data-qty-plus aria-label="Increase quantity">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </button>
            </div>

            {% render 'product-availability-button',
              product: product,
              button_class: 'pdp__atc-btn btn btn--primary btn--lg',
              button_size: 'lg',
              button_type: 'submit' %}
          </div>

          {%- comment -%} Buy Now {%- endcomment -%}
          {%- if product.available -%}
            {{ form | payment_button }}
          {%- endif -%}

        {%- endform -%}

        <div class="pdp__divider"></div>

        {%- comment -%} Trust Signals {%- endcomment -%}
        <div class="pdp__trust">
          <div class="pdp__trust-item">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <span>Free shipping on orders over $75</span>
          </div>
          <div class="pdp__trust-item">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
            <span>30-day hassle-free returns</span>
          </div>
          <div class="pdp__trust-item">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <span>Secure checkout — SSL encrypted</span>
          </div>
        </div>

        {%- comment -%} Product Meta {%- endcomment -%}
        <div class="pdp__meta">
          {%- if product.sku != blank -%}
            <p class="pdp__meta-item">
              <span class="pdp__meta-label">SKU:</span>
              <span id="pdp-sku">{{ product.selected_or_first_available_variant.sku }}</span>
            </p>
          {%- endif -%}
          {%- if product.type != blank -%}
            <p class="pdp__meta-item">
              <span class="pdp__meta-label">Type:</span>
              <a href="{{ product.type | url_for_type }}">{{ product.type }}</a>
            </p>
          {%- endif -%}
          {%- if product.tags.size > 0 -%}
            <p class="pdp__meta-item">
              <span class="pdp__meta-label">Tags:</span>
              {%- for tag in product.tags -%}
                <a href="{{ tag | url_for_tag }}" class="pdp__tag">{{ tag }}</a>{% unless forloop.last %}, {% endunless %}
              {%- endfor -%}
            </p>
          {%- endif -%}
        </div>

      </div>
    </div>

    {%- comment -%} ===== PRODUCT DETAILS TABS ===== {%- endcomment -%}
    <div class="pdp__tabs-section">
      <div class="tabs" role="tablist" aria-label="Product details">
        <button class="tabs__item tabs__item--active" role="tab" aria-selected="true" aria-controls="tab-description" id="tab-btn-description">Description</button>
        <button class="tabs__item" role="tab" aria-selected="false" aria-controls="tab-specs" id="tab-btn-specs">Specifications</button>
        <button class="tabs__item" role="tab" aria-selected="false" aria-controls="tab-shipping" id="tab-btn-shipping">Shipping & Returns</button>
        <button class="tabs__item" role="tab" aria-selected="false" aria-controls="tab-reviews" id="tab-btn-reviews">Reviews</button>
      </div>

      <div id="tab-description" class="pdp__tab-panel" role="tabpanel" aria-labelledby="tab-btn-description">
        <div class="pdp__description rte">
          {{ product.description }}
        </div>
      </div>

      <div id="tab-specs" class="pdp__tab-panel pdp__tab-panel--hidden" role="tabpanel" aria-labelledby="tab-btn-specs">
        <div class="pdp__specs">
          {%- for tag in product.tags -%}
            {%- if tag contains 'spec:' -%}
              {%- assign spec_parts = tag | remove: 'spec:' | split: '|' -%}
              {%- if spec_parts.size == 2 -%}
                <div class="pdp__spec-row">
                  <span class="pdp__spec-label">{{ spec_parts[0] | strip }}</span>
                  <span class="pdp__spec-value">{{ spec_parts[1] | strip }}</span>
                </div>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if product.weight > 0 -%}
            <div class="pdp__spec-row">
              <span class="pdp__spec-label">Weight</span>
              <span class="pdp__spec-value">{{ product.weight | weight_with_unit }}</span>
            </div>
          {%- endif -%}
        </div>
      </div>

      <div id="tab-shipping" class="pdp__tab-panel pdp__tab-panel--hidden" role="tabpanel" aria-labelledby="tab-btn-shipping">
        <div class="pdp__shipping-info">
          <div class="pdp__shipping-item">
            <h4>Shipping</h4>
            <p>Free standard shipping on all orders over $75. Orders placed before 2:00 PM PST ship same day. Expedited and overnight options available at checkout.</p>
          </div>
          <div class="pdp__shipping-item">
            <h4>Returns</h4>
            <p>Not satisfied? Return any item within 30 days for a full refund or exchange. Items must be in original, unused condition. Contact us to initiate a return.</p>
          </div>
          <div class="pdp__shipping-item">
            <h4>Warranty</h4>
            <p>All Jimbo's products are backed by our Craftsman Quality Guarantee. If a product fails due to a manufacturing defect, we'll replace it — no questions asked.</p>
          </div>
        </div>
      </div>

      <div id="tab-reviews" class="pdp__tab-panel pdp__tab-panel--hidden" role="tabpanel" aria-labelledby="tab-btn-reviews">
        <div class="pdp__reviews">
          {% render 'judgeme_widgets', widget_type: 'judgeme_review_widget', jm_style: '', concierge_install: false, product: product %}
        </div>
      </div>
    </div>

  </div>
</div>

<style>
  /* ============================================================
     PRODUCT DETAIL PAGE (PDP)
     ============================================================ */
  .pdp {
    padding-block: var(--space-8);
    background-color: var(--color-bg-primary);
  }

  /* Layout */
  .pdp__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: start;
    margin-bottom: var(--space-16);
  }

  /* Gallery */
  .pdp__main-image-wrap {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background-color: var(--color-bg-dark);
    aspect-ratio: 1/1;
  }

  .pdp__main-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity var(--transition-normal);
  }

  .pdp__main-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
  }

  .pdp__main-image-placeholder svg {
    width: 80px;
    height: 80px;
  }

  .pdp__badge {
    position: absolute;
    top: var(--space-4);
    left: var(--space-4);
    font-family: var(--font-heading);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--letter-spacing-wider);
    text-transform: uppercase;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-sm);
    color: var(--color-white);
  }

  .pdp__badge--sale { background-color: var(--color-ember-red); }
  .pdp__badge--new { background-color: var(--color-iron-green); }
  .pdp__badge--sold-out { background-color: var(--color-text-muted); }

  .pdp__thumbnails {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-4);
    flex-wrap: wrap;
  }

  .pdp__thumbnail {
    width: 72px;
    height: 72px;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 2px solid var(--color-border);
    background: none;
    padding: 0;
    cursor: pointer;
    transition: border-color var(--transition-fast);
    flex-shrink: 0;
  }

  .pdp__thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pdp__thumbnail:hover,
  .pdp__thumbnail--active {
    border-color: var(--color-accent-primary);
  }

  /* Info */
  .pdp__vendor {
    margin-bottom: var(--space-2);
  }

  .pdp__title {
    font-size: var(--font-size-4xl);
    margin-bottom: var(--space-3);
    line-height: var(--line-height-snug);
  }

  .pdp__rating {
    margin-bottom: var(--space-4);
  }

  .pdp__price-wrap {
    margin-bottom: var(--space-4);
  }

  .pdp__short-desc {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    margin-bottom: var(--space-4);
  }

  .pdp__divider {
    height: 1px;
    background: var(--color-border);
    margin-block: var(--space-6);
  }

  /* Variant Options */
  .pdp__option {
    margin-bottom: var(--space-5);
  }

  .pdp__option-label {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }

  .pdp__option-selected {
    color: var(--color-text-primary);
    font-weight: var(--font-weight-bold);
  }

  .pdp__option-buttons {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .pdp__option-btn {
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-heading);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background-color: var(--color-bg-dark);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .pdp__option-btn:hover {
    border-color: var(--color-text-secondary);
    color: var(--color-text-primary);
  }

  .pdp__option-btn--active {
    border-color: var(--color-accent-primary);
    background-color: rgba(230, 126, 34, 0.1);
    color: var(--color-accent-primary);
  }

  /* Swatches */
  .pdp__swatches {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .pdp__swatch {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 2px solid var(--color-border);
    background-color: var(--swatch-color, var(--color-bg-surface));
    cursor: pointer;
    transition: all var(--transition-fast);
    padding: 0;
  }

  .pdp__swatch:hover,
  .pdp__swatch--active {
    border-color: var(--color-accent-primary);
    box-shadow: 0 0 0 2px var(--color-bg-primary), 0 0 0 4px var(--color-accent-primary);
  }

  /* Purchase Row */
  .pdp__purchase-row {
    display: flex;
    gap: var(--space-4);
    align-items: center;
    margin-bottom: var(--space-4);
  }

  .pdp__atc-btn {
    flex: 1;
  }

  /* Trust */
  .pdp__trust {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .pdp__trust-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
  }

  .pdp__trust-item svg {
    width: 18px;
    height: 18px;
    color: var(--color-accent-primary);
    flex-shrink: 0;
  }

  /* Meta */
  .pdp__meta {
    margin-top: var(--space-6);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .pdp__meta-item {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .pdp__meta-label {
    font-family: var(--font-heading);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin-right: var(--space-2);
  }

  .pdp__tag {
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .pdp__tag:hover {
    color: var(--color-accent-primary);
  }

  /* Tabs Section */
  .pdp__tabs-section {
    margin-bottom: var(--space-16);
  }

  .pdp__tab-panel {
    padding-top: var(--space-8);
  }

  .pdp__tab-panel--hidden {
    display: none;
  }

  .pdp__description {
    max-width: 800px;
  }

  .pdp__description p,
  .pdp__description li {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    margin-bottom: var(--space-4);
  }

  .pdp__description h2,
  .pdp__description h3,
  .pdp__description h4 {
    color: var(--color-text-primary);
    margin-top: var(--space-6);
    margin-bottom: var(--space-3);
  }

  /* Specs */
  .pdp__specs {
    max-width: 600px;
  }

  .pdp__spec-row {
    display: flex;
    padding-block: var(--space-3);
    border-bottom: 1px solid var(--color-border);
    gap: var(--space-4);
  }

  .pdp__spec-label {
    font-family: var(--font-heading);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    color: var(--color-text-secondary);
    min-width: 160px;
    flex-shrink: 0;
  }

  .pdp__spec-value {
    font-size: var(--font-size-sm);
    color: var(--color-text-primary);
  }

  /* Shipping Info */
  .pdp__shipping-info {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
    max-width: 900px;
  }

  .pdp__shipping-item h4 {
    font-size: var(--font-size-base);
    margin-bottom: var(--space-3);
    color: var(--color-text-primary);
  }

  .pdp__shipping-item p {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    margin-bottom: 0;
  }

  /* Reviews */
  .pdp__reviews {
    max-width: 900px;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .pdp__layout {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .pdp__shipping-info {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }

  @media (max-width: 640px) {
    .pdp__purchase-row {
      flex-direction: column;
      align-items: stretch;
    }

    .pdp__title {
      font-size: var(--font-size-3xl);
    }
  }
</style>

<script>
  (function() {
    'use strict';

    // Gallery: thumbnail click
    const gallery = document.querySelector('[data-product-gallery]');
    if (gallery) {
      const mainImg = document.getElementById('pdp-main-image');
      const thumbs = gallery.querySelectorAll('[data-gallery-thumb]');

      thumbs.forEach(function(thumb) {
        thumb.addEventListener('click', function() {
          if (mainImg) {
            mainImg.src = this.dataset.galleryThumb;
          }
          thumbs.forEach(function(t) {
            t.classList.remove('pdp__thumbnail--active');
            t.setAttribute('aria-pressed', 'false');
          });
          this.classList.add('pdp__thumbnail--active');
          this.setAttribute('aria-pressed', 'true');
        });
      });
    }

    // Quantity selector
    const qtyInput = document.getElementById('pdp-quantity');
    if (qtyInput) {
      document.querySelector('[data-qty-minus]')?.addEventListener('click', function() {
        const val = parseInt(qtyInput.value, 10);
        if (val > 1) qtyInput.value = val - 1;
      });
      document.querySelector('[data-qty-plus]')?.addEventListener('click', function() {
        qtyInput.value = parseInt(qtyInput.value, 10) + 1;
      });
    }

    // Variant option buttons
    const optionGroups = document.querySelectorAll('[data-option-position]');
    const variantSelect = document.getElementById('pdp-variant-select');

    function updateVariant() {
      if (!variantSelect) return;
      const selectedOptions = [];
      optionGroups.forEach(function(group) {
        const active = group.querySelector('.pdp__option-btn--active, .pdp__swatch--active');
        if (active) selectedOptions.push(active.dataset.value);
      });

      for (let i = 0; i < variantSelect.options.length; i++) {
        const opt = variantSelect.options[i];
        const title = opt.text;
        const matches = selectedOptions.every(function(val) { return title.includes(val); });
        if (matches) {
          variantSelect.value = opt.value;
          variantSelect.dispatchEvent(new Event('change'));
          break;
        }
      }
    }

    optionGroups.forEach(function(group) {
      const btns = group.querySelectorAll('.pdp__option-btn, .pdp__swatch');
      btns.forEach(function(btn) {
        btn.addEventListener('click', function() {
          btns.forEach(function(b) {
            b.classList.remove('pdp__option-btn--active', 'pdp__swatch--active');
          });
          this.classList.add(
            this.classList.contains('pdp__swatch') ? 'pdp__swatch--active' : 'pdp__option-btn--active'
          );
          updateVariant();
        });
      });
    });

    // Tabs
    const tabBtns = document.querySelectorAll('[role="tab"]');
    tabBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        tabBtns.forEach(function(b) {
          b.classList.remove('tabs__item--active');
          b.setAttribute('aria-selected', 'false');
        });
        document.querySelectorAll('.pdp__tab-panel').forEach(function(panel) {
          panel.classList.add('pdp__tab-panel--hidden');
        });
        this.classList.add('tabs__item--active');
        this.setAttribute('aria-selected', 'true');
        const target = document.getElementById(this.getAttribute('aria-controls'));
        if (target) target.classList.remove('pdp__tab-panel--hidden');
      });
    });

  })();
</script>
