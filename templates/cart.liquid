{% comment %}
  JIMBO'S IRON & THREAD SUPPLY CO.
  Template: Cart Page
  Version: 2.0.0
  Description: Full cart page with line item editing, order summary,
               shipping estimate, and upsell section.
{% endcomment %}

<div class="cart-page">
  <div class="container">

    {%- comment -%} Page Header {%- endcomment -%}
    <div class="cart-page__header">
      {% render 'breadcrumbs' %}
      <h1 class="cart-page__title">Your Cart</h1>
      {%- if cart.item_count > 0 -%}
        <p class="cart-page__count">{{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }}</p>
      {%- endif -%}
    </div>

    {%- if cart.item_count == 0 -%}

      {%- comment -%} Empty Cart State {%- endcomment -%}
      <div class="cart-empty">
        <div class="cart-empty__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
        </div>
        <h2 class="cart-empty__heading">Your cart is empty</h2>
        <p class="cart-empty__text">Looks like you haven't added anything yet. Browse our craftsman-approved products.</p>
        <a href="/collections/all" class="btn btn--primary btn--lg">Shop All Products</a>
      </div>

    {%- else -%}

      <div class="cart-page__layout">

        {%- comment -%} ===== CART ITEMS ===== {%- endcomment -%}
        <div class="cart-page__items">

          <form action="/cart" method="post" class="cart-form" id="cart-form">
            <input type="hidden" name="checkout" value="Check Out">

            <div class="cart-items-list">
              {%- for item in cart.items -%}
                <div class="cart-item" data-key="{{ item.key }}">

                  {%- comment -%} Product Image {%- endcomment -%}
                  <a href="{{ item.url }}" class="cart-item__image-link" tabindex="-1" aria-hidden="true">
                    {%- if item.image != blank -%}
                      <img
                        class="cart-item__image"
                        src="{{ item.image | image_url: width: 160 }}"
                        alt="{{ item.image.alt | default: item.title | escape }}"
                        loading="lazy"
                        width="80"
                        height="80"
                      >
                    {%- else -%}
                      <div class="cart-item__image-placeholder" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                      </div>
                    {%- endif -%}
                  </a>

                  {%- comment -%} Item Details {%- endcomment -%}
                  <div class="cart-item__details">
                    <div class="cart-item__top">
                      <div>
                        {%- if item.product.vendor != blank -%}
                          <p class="cart-item__vendor">{{ item.product.vendor }}</p>
                        {%- endif -%}
                        <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
                        {%- unless item.product.has_only_default_variant -%}
                          <p class="cart-item__variant">{{ item.variant.title }}</p>
                        {%- endunless -%}
                        {%- for property in item.properties -%}
                          {%- unless property.last == blank or property.first contains '_' -%}
                            <p class="cart-item__property">{{ property.first }}: {{ property.last }}</p>
                          {%- endunless -%}
                        {%- endfor -%}
                      </div>
                      <button
                        type="button"
                        class="cart-item__remove"
                        data-remove-key="{{ item.key }}"
                        aria-label="Remove {{ item.product.title | escape }}"
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                      </button>
                    </div>

                    <div class="cart-item__bottom">
                      {%- comment -%} Quantity Selector {%- endcomment -%}
                      <div class="quantity-selector cart-item__quantity" data-qty-selector>
                        <button type="button" class="quantity-selector__btn" data-qty-decrement aria-label="Decrease quantity">
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        </button>
                        <input
                          type="number"
                          name="updates[]"
                          id="quantity-{{ item.key }}"
                          class="quantity-selector__input"
                          value="{{ item.quantity }}"
                          min="0"
                          data-cart-item-key="{{ item.key }}"
                          aria-label="Quantity for {{ item.product.title | escape }}"
                        >
                        <button type="button" class="quantity-selector__btn" data-qty-increment aria-label="Increase quantity">
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        </button>
                      </div>

                      {%- comment -%} Price {%- endcomment -%}
                      <div class="cart-item__price-wrap">
                        {%- if item.original_price != item.final_price -%}
                          <span class="cart-item__price cart-item__price--sale">{{ item.final_price | money }}</span>
                          <s class="cart-item__price--compare">{{ item.original_price | money }}</s>
                        {%- else -%}
                          <span class="cart-item__price">{{ item.final_price | money }}</span>
                        {%- endif -%}
                        {%- if item.quantity > 1 -%}
                          <span class="cart-item__unit-price">{{ item.final_price | money }} each</span>
                        {%- endif -%}
                      </div>
                    </div>
                  </div>

                </div>
              {%- endfor -%}
            </div>

            {%- comment -%} Cart Note {%- endcomment -%}
            <div class="cart-note">
              <label class="form-label" for="cart-note">Order Notes <span class="cart-note__optional">(optional)</span></label>
              <textarea
                id="cart-note"
                name="note"
                class="form-input cart-note__textarea"
                placeholder="Special instructions, delivery notes, or requests..."
                rows="3"
              >{{ cart.note }}</textarea>
            </div>

          </form>
        </div>

        {%- comment -%} ===== ORDER SUMMARY ===== {%- endcomment -%}
        <aside class="cart-summary" aria-label="Order summary">

          <div class="cart-summary__inner">
            <h2 class="cart-summary__title">Order Summary</h2>

            {%- comment -%} Line Items Subtotal {%- endcomment -%}
            <div class="cart-summary__line">
              <span>Subtotal ({{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }})</span>
              <span>{{ cart.total_price | money }}</span>
            </div>

            {%- comment -%} Discounts {%- endcomment -%}
            {%- for discount in cart.cart_level_discount_applications -%}
              <div class="cart-summary__line cart-summary__line--discount">
                <span>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="14" height="14"><polyline points="20 6 9 17 4 12"/></svg>
                  {{ discount.title }}
                </span>
                <span>-{{ discount.total_allocated_amount | money }}</span>
              </div>
            {%- endfor -%}

            {%- comment -%} Free shipping nudge {%- endcomment -%}
            {%- assign free_shipping_threshold = 7500 -%}
            {%- assign cart_total = cart.total_price -%}
            {%- if cart_total < free_shipping_threshold -%}
              {%- assign remaining = free_shipping_threshold | minus: cart_total -%}
              <div class="cart-summary__shipping-nudge">
                <div class="cart-summary__nudge-bar">
                  <div
                    class="cart-summary__nudge-fill"
                    style="width: {{ cart_total | times: 100 | divided_by: free_shipping_threshold }}%"
                  ></div>
                </div>
                <p>Add <strong>{{ remaining | money }}</strong> more for <strong>free shipping</strong></p>
              </div>
            {%- else -%}
              <div class="cart-summary__free-shipping">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                You qualify for <strong>free shipping!</strong>
              </div>
            {%- endif -%}

            <div class="cart-summary__divider"></div>

            <div class="cart-summary__total">
              <span>Estimated Total</span>
              <span class="cart-summary__total-price">{{ cart.total_price | money }}</span>
            </div>

            <p class="cart-summary__tax-note">Taxes and shipping calculated at checkout</p>

            {%- comment -%} Loyalty points display {%- endcomment -%}
            {% render 'loyalty-program', context: 'cart' %}

            {%- comment -%} Checkout Button {%- endcomment -%}
            <a
              href="/checkout"
              class="btn btn--primary btn--full btn--lg cart-summary__checkout-btn"
              id="cart-checkout-btn"
            >
              Proceed to Checkout
            </a>

            <a href="/collections/all" class="btn btn--ghost btn--full btn--sm cart-summary__continue">
              ← Continue Shopping
            </a>

            {%- comment -%} Payment Icons {%- endcomment -%}
            {%- if shop.enabled_payment_types.size > 0 -%}
              <div class="cart-summary__payments">
                {%- for type in shop.enabled_payment_types -%}
                  {{ type | payment_type_svg_tag: class: 'payment-icon' }}
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>
        </aside>

      </div>

    {%- endif -%}

  </div>
</div>

<style>
  .cart-page {
    min-height: 60vh;
    background-color: var(--color-bg-dark);
    padding-block: var(--space-12) var(--space-20);
  }

  .cart-page__header {
    margin-bottom: var(--space-10);
  }

  .cart-page__title {
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--color-white);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-tight);
    margin-top: var(--space-4);
    margin-bottom: var(--space-2);
  }

  .cart-page__count {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    margin-bottom: 0;
  }

  /* Empty State */
  .cart-empty {
    text-align: center;
    padding-block: var(--space-24);
    max-width: 480px;
    margin-inline: auto;
  }

  .cart-empty__icon {
    width: 80px;
    height: 80px;
    background-color: rgba(230, 126, 34, 0.1);
    border: 1px solid rgba(230, 126, 34, 0.2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-inline: auto;
    margin-bottom: var(--space-6);
    color: var(--color-accent-primary);
  }

  .cart-empty__icon svg { width: 36px; height: 36px; }

  .cart-empty__heading {
    font-size: var(--font-size-2xl);
    color: var(--color-white);
    margin-bottom: var(--space-3);
  }

  .cart-empty__text {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
    line-height: var(--line-height-relaxed);
  }

  /* Layout */
  .cart-page__layout {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: var(--space-10);
    align-items: start;
  }

  /* Cart Items */
  .cart-items-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .cart-item {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: var(--space-5);
    padding: var(--space-5);
    background-color: var(--color-bg-surface);
    border-bottom: 1px solid var(--color-border);
    transition: background-color var(--transition-fast);
  }

  .cart-item:last-child { border-bottom: none; }
  .cart-item:hover { background-color: rgba(255, 255, 255, 0.02); }

  .cart-item__image-link { display: block; }

  .cart-item__image {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
  }

  .cart-item__image-placeholder {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, var(--color-bg-dark) 0%, var(--color-bg-surface) 100%);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
  }

  .cart-item__image-placeholder svg { width: 28px; height: 28px; }

  .cart-item__details { display: flex; flex-direction: column; gap: var(--space-3); }

  .cart-item__top {
    display: flex;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .cart-item__vendor {
    font-family: var(--font-heading);
    font-size: var(--font-size-xs);
    letter-spacing: var(--letter-spacing-wider);
    text-transform: uppercase;
    color: var(--color-accent-primary);
    margin-bottom: var(--space-1);
  }

  .cart-item__title {
    font-family: var(--font-heading);
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-bold);
    color: var(--color-text-primary);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-tight);
    line-height: var(--line-height-snug);
  }

  .cart-item__title:hover { color: var(--color-accent-primary); }

  .cart-item__variant,
  .cart-item__property {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    margin-top: var(--space-1);
  }

  .cart-item__remove {
    background: none;
    border: none;
    padding: var(--space-1);
    cursor: pointer;
    color: var(--color-text-muted);
    flex-shrink: 0;
    border-radius: var(--radius-sm);
    transition: color var(--transition-fast), background-color var(--transition-fast);
  }

  .cart-item__remove:hover {
    color: var(--color-ember-red);
    background-color: rgba(192, 57, 43, 0.1);
  }

  .cart-item__remove svg { width: 18px; height: 18px; display: block; }

  .cart-item__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .cart-item__price-wrap { text-align: right; }

  .cart-item__price {
    font-family: var(--font-heading);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    color: var(--color-text-primary);
  }

  .cart-item__price--sale { color: var(--color-accent-primary); }

  .cart-item__price--compare {
    display: block;
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
  }

  .cart-item__unit-price {
    display: block;
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
  }

  /* Cart Note */
  .cart-note {
    margin-top: var(--space-6);
  }

  .cart-note__optional {
    font-weight: var(--font-weight-regular);
    font-style: italic;
    color: var(--color-text-muted);
    font-family: var(--font-body);
    text-transform: none;
    letter-spacing: 0;
    font-size: var(--font-size-xs);
  }

  .cart-note__textarea {
    resize: vertical;
    min-height: 80px;
  }

  /* Cart Summary */
  .cart-summary__inner {
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    position: sticky;
    top: var(--space-6);
  }

  .cart-summary__title {
    font-size: var(--font-size-xl);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-tight);
    margin-bottom: var(--space-5);
    color: var(--color-white);
  }

  .cart-summary__line {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    padding-block: var(--space-2);
  }

  .cart-summary__line--discount {
    color: var(--color-iron-green);
    font-family: var(--font-heading);
    font-size: var(--font-size-xs);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
  }

  .cart-summary__line--discount span:first-child {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .cart-summary__shipping-nudge {
    margin-block: var(--space-4);
    padding: var(--space-4);
    background-color: rgba(230, 126, 34, 0.06);
    border: 1px solid rgba(230, 126, 34, 0.2);
    border-radius: var(--radius-md);
  }

  .cart-summary__nudge-bar {
    height: 4px;
    background-color: var(--color-border);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: var(--space-3);
  }

  .cart-summary__nudge-fill {
    height: 100%;
    background-color: var(--color-accent-primary);
    border-radius: 2px;
    transition: width var(--transition-normal);
  }

  .cart-summary__shipping-nudge p {
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    margin: 0;
    line-height: var(--line-height-normal);
  }

  .cart-summary__free-shipping {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-block: var(--space-4);
    padding: var(--space-3) var(--space-4);
    background-color: rgba(39, 174, 96, 0.1);
    border: 1px solid rgba(39, 174, 96, 0.25);
    border-radius: var(--radius-md);
    font-size: var(--font-size-xs);
    color: var(--color-iron-green);
  }

  .cart-summary__free-shipping svg { width: 16px; height: 16px; flex-shrink: 0; }

  .cart-summary__divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin-block: var(--space-4);
  }

  .cart-summary__total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-heading);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
    color: var(--color-white);
    font-size: var(--font-size-base);
    margin-bottom: var(--space-2);
  }

  .cart-summary__total-price {
    font-size: var(--font-size-xl);
    color: var(--color-accent-primary);
  }

  .cart-summary__tax-note {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    margin-bottom: var(--space-5);
  }

  .cart-summary__checkout-btn {
    margin-bottom: var(--space-3);
  }

  .cart-summary__continue {
    font-size: var(--font-size-xs);
  }

  .cart-summary__payments {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    justify-content: center;
    margin-top: var(--space-5);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .cart-summary__payments .payment-icon {
    height: 22px;
    width: auto;
    border-radius: 3px;
    opacity: 0.7;
  }

  @media (max-width: 900px) {
    .cart-page__layout {
      grid-template-columns: 1fr;
    }

    .cart-summary__inner {
      position: static;
    }
  }

  @media (max-width: 560px) {
    .cart-item {
      grid-template-columns: 64px 1fr;
      padding: var(--space-4);
    }

    .cart-item__image,
    .cart-item__image-placeholder {
      width: 64px;
      height: 64px;
    }
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
  // Remove item buttons
  document.querySelectorAll('[data-remove-key]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var key = this.getAttribute('data-remove-key');
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: key, quantity: 0 })
      }).then(function () {
        window.location.reload();
      });
    });
  });

  // Quantity updates
  document.querySelectorAll('[data-cart-item-key]').forEach(function (input) {
    var debounceTimer;
    input.addEventListener('change', function () {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(function () {
        fetch('/cart/change.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: input.getAttribute('data-cart-item-key'), quantity: parseInt(input.value, 10) })
        }).then(function () {
          window.location.reload();
        });
      }, 400);
    });
  });
});
</script>
